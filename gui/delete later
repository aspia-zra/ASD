# Repairs button
repairsBtn = Button( 
    sidebar, 
    text="Repairs", 
    bg=SIDEBAR_COLOR, 
    fg=TEXT_COLOR, 
    relief=FLAT, 
    command=lambda: open_repairs(main) 
) 
repairsBtn.pack(pady=10, fill="x") 
repairsBtn.bind("<Enter>", lambda e: repairsBtn.config(bg=SUB_ACCENT)) 
repairsBtn.bind("<Leave>", lambda e: repairsBtn.config(bg=SIDEBAR_COLOR)) 
    
    
